# ── Vault Peptides — environment template ────────────────────────────
# Copy this file to `.env` and fill in the values.
#
# LOCAL (zero-config): keep DATABASE_URL as the SQLite file below — no
# external database required. `npm run dev` just works.
#
# PRODUCTION: switch prisma/schema.prisma datasource provider to "postgresql"
# and set DATABASE_URL to your Postgres connection string (Neon / Supabase).

DATABASE_URL="file:./dev.db"

# Auth (NextAuth v5). Generate with:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-string"
NEXTAUTH_SECRET="replace-with-a-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Business WhatsApp number (digits only, country code first)
WHATSAPP_NUMBER="918722579999"

# Seeded admin login (change these!)
ADMIN_EMAIL="admin@vaultpeptides.shop"
ADMIN_PASSWORD="VaultAdmin@123"

# Optional Google OAuth (leave blank to disable Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
